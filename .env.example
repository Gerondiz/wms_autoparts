# Database
# Примечание: Порт 5435 используется в Docker, 5432 для локальной БД
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/wms_autoparts?schema=public"

# NextAuth
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Application
NEXT_PUBLIC_APP_NAME="WMS Autoparts"
NEXT_PUBLIC_DEFAULT_LOCALE="ru"

# Upload
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="5242880"

# Docker/Production
NODE_ENV="production"
PORT="3000"
HOSTNAME="0.0.0.0"
