/**
 * Middleware для WMS Autoparts
 * 
 * Упрощённая версия без i18n (обработка в layout)
 */

import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';

/**
 * Основной middleware
 */
export default function middleware(request: NextRequest) {
  const { nextUrl } = request;
  const pathname = nextUrl.pathname;

  // ==================== API Routes ====================
  
  // Health check endpoint (публичный)
  if (pathname === '/api/health') {
    return NextResponse.next();
  }

  // ==================== Статические файлы ====================
  
  if (
    pathname.startsWith('/_next') ||
    pathname.startsWith('/static') ||
    pathname.includes('.')
  ) {
    return NextResponse.next();
  }

  // ==================== Редирект с корня на /ru ====================
  
  if (pathname === '/') {
    return NextResponse.redirect(new URL('/ru', request.url));
  }

  // ==================== RTL Cookie для арабского ====================
  
  const localePattern = /^\/(ru|en|ar)(\/|$)/;
  const locale = pathname.match(localePattern)?.[1] || 'ru';
  
  const response = NextResponse.next();
  
  if (locale === 'ar') {
    response.cookies.set('dir', 'rtl', {
      path: '/',
      maxAge: 60 * 60 * 24 * 365,
      sameSite: 'lax',
    });
  } else {
    response.cookies.set('dir', 'ltr', {
      path: '/',
      maxAge: 60 * 60 * 24 * 365,
      sameSite: 'lax',
    });
  }

  return response;
}

/**
 * Конфигурация matcher для middleware
 */
export const config = {
  matcher: [
    /*
     * Match all request paths except:
     * - _next/static (static files)
     * - _next/image (image optimization files)
     * - favicon.ico (favicon file)
     * - public files (robots.txt, sitemap.xml, etc.)
     */
    '/((?!_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',
  ],
};
